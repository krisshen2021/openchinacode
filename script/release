#!/usr/bin/env bash
set -euo pipefail

VERSION=${1:-}
PRERELEASE=${2:-false}

if [[ -z "$VERSION" ]]; then
  echo "Usage: script/release <version> [prerelease]"
  echo "Example: script/release 0.1.0"
  exit 1
fi

VERSION=${VERSION#v}

gh workflow run release.yml -f version="$VERSION" -f prerelease="$PRERELEASE"
